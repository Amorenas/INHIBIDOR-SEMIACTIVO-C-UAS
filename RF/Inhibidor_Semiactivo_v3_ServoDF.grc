- name: angle_sweep
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"Angle sweep generator for a servo-style scan.\n\n    Outputs a float\
      \ stream 'angle_deg' that sweeps between min_angle_deg and max_angle_deg.\n\
      \    Intended to drive an external servo controller (e.g., via another block/serial),\n\
      \    or to tag measurements with the current pointing angle.\n\n    This is\
      \ *passive direction finding* by amplitude (scan + max RSSI), not interferer\
      \ control.\n    \"\"\"\n\n    def __init__(self, rate_hz=20.0, min_angle_deg=-60.0,\
      \ max_angle_deg=60.0, speed_deg_s=30.0):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='Angle Sweep (deg)',\n            in_sig=None,\n\
      \            out_sig=[np.float32],\n        )\n        self.rate = float(rate_hz)\n\
      \        self.min_a = float(min_angle_deg)\n        self.max_a = float(max_angle_deg)\n\
      \        self.speed = float(speed_deg_s)\n\n        self.angle = self.min_a\n\
      \        self.dir = 1.0\n        self.step = self.speed / max(self.rate, 1e-9)\n\
      \n    def work(self, input_items, output_items):\n        out = output_items[0]\n\
      \        n = len(out)\n        for i in range(n):\n            out[i] = np.float32(self.angle)\n\
      \            self.angle += self.dir * self.step\n            if self.angle >=\
      \ self.max_a:\n                self.angle = self.max_a\n                self.dir\
      \ = -1.0\n            elif self.angle <= self.min_a:\n                self.angle\
      \ = self.min_a\n                self.dir = 1.0\n        return n"
    affinity: ''
    alias: ''
    comment: ''
    max_angle_deg: '60'
    maxoutbuf: '0'
    min_angle_deg: '-60'
    minoutbuf: '0'
    rate_hz: ui_rate
    speed_deg_s: scan_speed_deg_s
  states:
    _io_cache: ('Angle Sweep (deg)', 'blk', [('rate_hz', '20.0'), ('min_angle_deg',
      '-60.0'), ('max_angle_deg', '60.0'), ('speed_deg_s', '30.0')], [], [('0', 'float',
      1)], "Angle sweep generator for a servo-style scan.\n\n    Outputs a float stream
      'angle_deg' that sweeps between min_angle_deg and max_angle_deg.\n    Intended
      to drive an external servo controller (e.g., via another block/serial),\n    or
      to tag measurements with the current pointing angle.\n\n    This is *passive
      direction finding* by amplitude (scan + max RSSI), not interferer control.\n    ",
      [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1944, 488.0]
    rotation: 0
    state: enabled
- name: chirp_source
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Generador de Chirp Continuo para barrido de frecuencia.\n \
      \   \n    Genera se\xF1al compleja cuya frecuencia varia linealmente:\n    \
      \    f(t) = -BW/2  \u2192  +BW/2  en sweep_time segundos\n    \n    La portadora\
      \ del PlutoSDR+ se fija en center_freq.\n    El chirp en banda base produce\
      \ el barrido RF:\n        2.400 GHz  \u2192  2.420 GHz\n    \"\"\"\n\n    def\
      \ __init__(self, sample_rate=20000000, sweep_bw=20000000, sweep_time=0.490,\
      \ amplitude=0.9):\n        gr.sync_block.__init__(\n            self,\n    \
      \        name='Chirp Sweep Source',\n            in_sig=None,\n            out_sig=[np.complex64],\n\
      \        )\n        self.sample_rate = sample_rate\n        self.sweep_bw  \
      \  = sweep_bw\n        self.sweep_time  = sweep_time\n        self.amplitude\
      \   = amplitude\n        self.samples_per_sweep = int(sample_rate * sweep_time)\n\
      \        self.chirp_rate = sweep_bw / self.samples_per_sweep\n        self.sample_idx\
      \ = 0\n\n    def work(self, input_items, output_items):\n        n = len(output_items[0])\n\
      \        idx = np.arange(self.sample_idx, self.sample_idx + n)\n        pos\
      \ = idx % self.samples_per_sweep\n        # Fase cuadratica: garantiza continuidad\
      \ y barrido lineal\n        phase = 2 * np.pi * (\n            (self.chirp_rate\
      \ / (2 * self.sample_rate)) * pos**2\n            - (self.sweep_bw / (2 * self.sample_rate))\
      \ * pos\n        )\n        output_items[0][:n] = (self.amplitude * np.exp(1j\
      \ * phase)).astype(np.complex64)\n        self.sample_idx += n\n        return\
      \ n\n"
    affinity: ''
    alias: ''
    amplitude: '0.9'
    comment: "CHIRP SOURCE\nGenera barrido continuo -10MHz a +10MHz\nen banda base.\n\
      Con portadora en 2.410 GHz produce:\n2.400 GHz \u2192 2.420 GHz en RF"
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: samp_rate
    sweep_bw: sweep_bw
    sweep_time: sweep_time
  states:
    _io_cache: "('Chirp Sweep Source', 'blk', [('sample_rate', '20000000'), ('sweep_bw',\
      \ '20000000'), ('sweep_time', '0.49'), ('amplitude', '0.9')], [], [('0', 'complex',\
      \ 1)], '\\n    Generador de Chirp Continuo para barrido de frecuencia.\\n  \
      \  \\n    Genera se\xF1al compleja cuya frecuencia varia linealmente:\\n   \
      \     f(t) = -BW/2  \u2192  +BW/2  en sweep_time segundos\\n    \\n    La portadora\
      \ del PlutoSDR+ se fija en center_freq.\\n    El chirp en banda base produce\
      \ el barrido RF:\\n        2.400 GHz  \u2192  2.420 GHz\\n    ', ['amplitude',\
      \ 'sample_rate', 'sweep_bw', 'sweep_time'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [0, 656.0]
    rotation: 0
    state: enabled
- name: doa_estimator_future
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    FUTURO: Estimador DOA para segundo PlutoSDR receptor.\n   \
      \ \n    Algoritmo: MUSIC (MUltiple SIgnal Classification)\n    Entrada: se\xF1\
      al IQ del PlutoSDR receptor\n    Salida: angulo estimado en radianes \u2192\
      \ alimenta phase_shift\n    \n    Para habilitar:\n    1. Conectar PlutoSDR\
      \ RX a la entrada de este bloque\n    2. Conectar salida a variable beam_angle_deg\n\
      \    3. El slider pasa a modo visualizacion\n    \n    Separacion antenas RX:\
      \ lambda = 12.5 cm @ 2.4 GHz\n    \"\"\"\n\n    def __init__(self, sample_rate=20000000,\
      \ ant_separation=0.125, freq=2410000000):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='DOA Estimator (MUSIC)',\n            in_sig=[np.complex64],\n\
      \            out_sig=[np.float32],  # angulo en grados\n        )\n        self.sample_rate\
      \ = sample_rate\n        self.ant_separation = ant_separation\n        self.wavelength\
      \ = 3e8 / freq\n        self.buffer = []\n        self.buffer_size = 1024\n\n\
      \    def work(self, input_items, output_items):\n        \"\"\"\n        PENDIENTE\
      \ DE IMPLEMENTACION:\n        - Acumular muestras del PlutoSDR RX\n        -\
      \ Calcular matriz de covarianza R = E[x*x^H]\n        - Aplicar MUSIC: eigendescomposicion\
      \ de R\n        - Buscar pico en espectro espacial MUSIC\n        - Retornar\
      \ angulo en grados\n        \"\"\"\n        n = len(input_items[0])\n      \
      \  # Placeholder: retorna 0 grados hasta implementacion real\n        output_items[0][:n]\
      \ = np.zeros(n, dtype=np.float32)\n        return n\n"
    affinity: ''
    alias: ''
    ant_separation: ant_separation
    comment: "FUTURO: DOA con segundo PlutoSDR\nALGORITMO: MUSIC\nENTRADA: IQ del\
      \ PlutoSDR RX\nSALIDA: angulo estimado \u2192 beam_angle_deg\nESTADO: DESHABILITADO\
      \ hasta tener 2\xBA Pluto"
    freq: center_freq
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: samp_rate
  states:
    _io_cache: "('DOA Estimator (MUSIC)', 'blk', [('sample_rate', '20000000'), ('ant_separation',\
      \ '0.125'), ('freq', '2410000000')], [('0', 'complex', 1)], [('0', 'float',\
      \ 1)], '\\n    FUTURO: Estimador DOA para segundo PlutoSDR receptor.\\n    \\\
      n    Algoritmo: MUSIC (MUltiple SIgnal Classification)\\n    Entrada: se\xF1\
      al IQ del PlutoSDR receptor\\n    Salida: angulo estimado en radianes \u2192\
      \ alimenta phase_shift\\n    \\n    Para habilitar:\\n    1. Conectar PlutoSDR\
      \ RX a la entrada de este bloque\\n    2. Conectar salida a variable beam_angle_deg\\\
      n    3. El slider pasa a modo visualizacion\\n    \\n    Separacion antenas\
      \ RX: lambda = 12.5 cm @ 2.4 GHz\\n    ', ['ant_separation', 'sample_rate'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1944, 248.0]
    rotation: 0
    state: disabled
- name: doa_music_rx
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Estimador DOA MUSIC para ULA de 2 elementos.\n\n    Entradas:\n\
      \        in0 (complex): se\xF1al RX antena 1 (referencia)\n        in1 (complex):\
      \ se\xF1al RX antena 2 (desfasada)\n\n    Salida:\n        out0 (float): angulo\
      \ DOA estimado en GRADOS\n\n    Algoritmo MUSIC simplificado para 2 elementos:\n\
      \        - Calcula matriz de correlacion cruzada\n        - Estima angulo por\
      \ maxima correlacion\n        - Suavizado exponencial para estabilidad\n\n \
      \   Para arrays mayores usar scipy/numpy eigendec completo.\n    \"\"\"\n\n\
      \    def __init__(self, sample_rate=20000000, ant_separation=0.0625,\n     \
      \            freq=2410000000, smooth=0.05, block_size=1024):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='DOA MUSIC 2-element',\n            in_sig=[np.complex64,\
      \ np.complex64],\n            out_sig=[np.float32],\n        )\n        self.sample_rate\
      \   = sample_rate\n        self.ant_sep       = ant_separation\n        self.wavelength\
      \    = 3e8 / freq\n        self.smooth        = smooth          # coef. suavizado\
      \ EMA\n        self.block_size    = block_size\n        self.set_output_multiple(block_size)\n\
      \n        # Grilla de angulos de busqueda\n        self.angles_deg  = np.linspace(-90,\
      \ 90, 361)\n        self.angles_rad  = np.radians(self.angles_deg)\n\n     \
      \   # Vectores steering para cada angulo\n        self.d_over_lam  = ant_separation\
      \ / self.wavelength\n        self.steering    = np.exp(\n            1j * 2\
      \ * np.pi * self.d_over_lam * np.sin(self.angles_rad)\n        )  # shape (361,)\n\
      \n        self.doa_smooth  = 0.0   # estado interno suavizado\n\n    def work(self,\
      \ input_items, output_items):\n        n = self.block_size\n        x1 = input_items[0][:n]\n\
      \        x2 = input_items[1][:n]\n\n        # \u2500\u2500 Matriz de correlacion\
      \ cruzada (2x2) \u2500\u2500\n        r11 = np.mean(x1 * np.conj(x1)).real\n\
      \        r12 = np.mean(x1 * np.conj(x2))\n        r21 = np.conj(r12)\n     \
      \   r22 = np.mean(x2 * np.conj(x2)).real\n        R = np.array([[r11, r12],\n\
      \                      [r21, r22]])\n\n        # \u2500\u2500 Eigendescomposicion\
      \ \u2500\u2500\n        eigvals, eigvecs = np.linalg.eigh(R)\n        # Subespacio\
      \ de ruido: eigenvector con menor eigenvalor\n        noise_vec = eigvecs[:,\
      \ 0]  # shape (2,)\n\n        # \u2500\u2500 Pseudoespectro MUSIC \u2500\u2500\
      \n        # a(theta) = [1, exp(j*2pi*(d/lam)*sin(theta))]\n        a = np.stack([np.ones(361),\
      \ self.steering], axis=0)  # (2, 361)\n        # P_music(theta) = 1 / |a^H *\
      \ En * En^H * a|\n        En = noise_vec[:, np.newaxis]             # (2,1)\n\
      \        proj = En @ En.conj().T                   # (2,2) noise projector\n\
      \        denom = np.abs(\n            np.einsum('ij,jk,ki->i',\n           \
      \           a.conj().T,   # (361,2)\n                      proj,          #\
      \ (2,2)\n                      a)             # (2,361)\n        ) + 1e-12\n\
      \        music_spectrum = 1.0 / denom              # (361,)\n\n        # \u2500\
      \u2500 Pico del espectro \u2192 angulo estimado \u2500\u2500\n        peak_idx\
      \  = int(np.argmax(music_spectrum))\n        doa_raw   = float(self.angles_deg[peak_idx])\n\
      \n        # \u2500\u2500 Suavizado exponencial (EMA) \u2500\u2500\n        self.doa_smooth\
      \ = (\n            self.smooth * doa_raw +\n            (1.0 - self.smooth)\
      \ * self.doa_smooth\n        )\n\n        output_items[0][:n] = np.full(n, self.doa_smooth,\
      \ dtype=np.float32)\n        return n\n"
    affinity: ''
    alias: ''
    ant_separation: ant_separation
    block_size: '1024'
    comment: "DOA MUSIC 2 ELEMENTOS\nEntradas: RX1, RX2 del PlutoSDR sensor\nSalida:\
      \ angulo en grados \u2192 beam_angle_deg\nSuavizado EMA=0.05 para estabilidad\n\
      Grilla: -90 a +90 en 361 puntos (0.5 deg resolucion)"
    freq: center_freq
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: samp_rate
    smooth: '0.05'
  states:
    _io_cache: "('DOA MUSIC 2-element', 'blk', [('sample_rate', '20000000'), ('ant_separation',\
      \ '0.0625'), ('freq', '2410000000'), ('smooth', '0.05'), ('block_size', '1024')],\
      \ [('0', 'complex', 1), ('1', 'complex', 1)], [('0', 'float', 1)], '\\n    Estimador\
      \ DOA MUSIC para ULA de 2 elementos.\\n\\n    Entradas:\\n        in0 (complex):\
      \ se\xF1al RX antena 1 (referencia)\\n        in1 (complex): se\xF1al RX antena\
      \ 2 (desfasada)\\n\\n    Salida:\\n        out0 (float): angulo DOA estimado\
      \ en GRADOS\\n\\n    Algoritmo MUSIC simplificado para 2 elementos:\\n     \
      \   - Calcula matriz de correlacion cruzada\\n        - Estima angulo por maxima\
      \ correlacion\\n        - Suavizado exponencial para estabilidad\\n\\n    Para\
      \ arrays mayores usar scipy/numpy eigendec completo.\\n    ', ['block_size',\
      \ 'sample_rate', 'smooth'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [256, 1224.0]
    rotation: 0
    state: disabled
- name: iio_pluto_sink_0
  id: iio_pluto_sink
  parameters:
    affinity: ''
    alias: ''
    attenuation1: '10'
