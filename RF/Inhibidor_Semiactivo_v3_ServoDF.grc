- name: null_steering_tx
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Null Steering para ULA de 2 antenas TX.\n\n    Modifica los\
      \ pesos de las dos antenas TX para\n    colocar un nulo en la direccion null_angle_deg.\n\
      \n    Entradas:\n        in0 (complex): se\xF1al TX (chirp) para antena 1\n\
      \        in1 (complex): se\xF1al TX (chirp) para antena 2 (pre-beamforming)\n\
      \n    Salidas:\n        out0 (complex): se\xF1al antena 1 con peso null steering\n\
      \        out1 (complex): se\xF1al antena 2 con peso null steering\n\n    El\
      \ null steering se combina con el beamforming previo:\n    w_null = I - a*a^H/||a||^2\n\
      \    w_beam = [1, exp(j*phi)]\n    w_total = w_null * w_beam\n    \"\"\"\n\n\
      \    def __init__(self, sample_rate=20000000, ant_separation=0.0625,\n     \
      \            freq=2410000000, null_angle_deg=0.0, beam_angle_deg=0.0):\n   \
      \     gr.sync_block.__init__(\n            self,\n            name='Null Steering\
      \ 2-ant',\n            in_sig=[np.complex64, np.complex64],\n            out_sig=[np.complex64,\
      \ np.complex64],\n        )\n        self.ant_sep     = ant_separation\n   \
      \     self.wavelength  = 3e8 / freq\n        self.null_angle  = null_angle_deg\n\
      \        self.beam_angle  = beam_angle_deg\n        self._update_weights()\n\
      \n    def _update_weights(self):\n        d_lam = self.ant_sep / self.wavelength\n\
      \        # Steering vector beamforming\n        phi_beam = 2 * np.pi * d_lam\
      \ * np.sin(np.radians(self.beam_angle))\n        a_beam   = np.array([1.0, np.exp(1j\
      \ * phi_beam)])\n\n        # Steering vector null\n        phi_null = 2 * np.pi\
      \ * d_lam * np.sin(np.radians(self.null_angle))\n        a_null   = np.array([1.0,\
      \ np.exp(1j * phi_null)])\n\n        # Proyector ortogonal al nulo\n       \
      \ # P_null = I - a_null * a_null^H / ||a_null||^2\n        P_null = np.eye(2)\
      \ - np.outer(a_null, a_null.conj()) / np.dot(a_null, a_null.conj()).real\n\n\
      \        # Pesos finales\n        w = P_null @ a_beam\n        # Normalizar\
      \ para mantener potencia\n        norm = np.linalg.norm(w)\n        if norm\
      \ > 1e-9:\n            w = w / norm\n        self.w0 = np.complex64(w[0])\n\
      \        self.w1 = np.complex64(w[1])\n\n    def set_null_angle_deg(self, val):\n\
      \        self.null_angle = float(val)\n        self._update_weights()\n\n  \
      \  def set_beam_angle_deg(self, val):\n        self.beam_angle = float(val)\n\
      \        self._update_weights()\n\n    def work(self, input_items, output_items):\n\
      \        n = len(output_items[0])\n        output_items[0][:n] = input_items[0][:n]\
      \ * self.w0\n        output_items[1][:n] = input_items[1][:n] * self.w1\n  \
      \      return n\n"
    affinity: ''
    alias: ''
    ant_separation: ant_separation
    beam_angle_deg: beam_angle_deg
    comment: 'NULL STEERING TX

      Combina beamforming + null steering

      w_total = P_null * w_beam

      null_angle_deg: controlado por slider

      beam_angle_deg: del DOA automatico o slider manual'
    freq: center_freq
    maxoutbuf: '0'
    minoutbuf: '0'
    null_angle_deg: '0.0'
    sample_rate: samp_rate
  states:
    _io_cache: "('Null Steering 2-ant', 'blk', [('sample_rate', '20000000'), ('ant_separation',\
      \ '0.0625'), ('freq', '2410000000'), ('null_angle_deg', '0.0'), ('beam_angle_deg',\
      \ '0.0')], [('0', 'complex', 1), ('1', 'complex', 1)], [('0', 'complex', 1),\
      \ ('1', 'complex', 1)], '\\n    Null Steering para ULA de 2 antenas TX.\\n\\\
      n    Modifica los pesos de las dos antenas TX para\\n    colocar un nulo en\
      \ la direccion null_angle_deg.\\n\\n    Entradas:\\n        in0 (complex): se\xF1\
      al TX (chirp) para antena 1\\n        in1 (complex): se\xF1al TX (chirp) para\
      \ antena 2 (pre-beamforming)\\n\\n    Salidas:\\n        out0 (complex): se\xF1\
      al antena 1 con peso null steering\\n        out1 (complex): se\xF1al antena\
      \ 2 con peso null steering\\n\\n    El null steering se combina con el beamforming\
      \ previo:\\n    w_null = I - a*a^H/||a||^2\\n    w_beam = [1, exp(j*phi)]\\\
      n    w_total = w_null * w_beam\\n    ', [])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [536, 704.0]
    rotation: 0
    state: disabled
