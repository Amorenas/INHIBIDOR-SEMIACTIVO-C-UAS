      del segundo PlutoSDR receptor.'
    gui_hint: 0,0,1,1
    label: Angulo Beamforming (grados)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-90'
    step: '1'
    stop: '90'
    value: '0'
    widget: slider
  states:
