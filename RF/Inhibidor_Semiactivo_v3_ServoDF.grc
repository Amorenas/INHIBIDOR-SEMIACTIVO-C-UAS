- name: rssi_real
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Medidor de RSSI real a partir de muestras IQ del PlutoSDR.\n\
      \n    Calcula la potencia media en dB de cada bloque de muestras:\n        RSSI_dB\
      \ = 10*log10(mean(|x|^2) + eps)\n\n    Entrada:  IQ del PlutoSDR RX (complex64)\n\
      \    Salida:   RSSI en dBFS (float32)\n\n    Uso: conectar salida al rssi_best_tracker\
      \ para\n    combinar con el angulo actual del servo.\n    \"\"\"\n\n    def\
      \ __init__(self, block_size=1024, smooth=0.2):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='RSSI Meter (dBFS)',\n            in_sig=[np.complex64],\n\
      \            out_sig=[np.float32],\n        )\n        self.block_size = block_size\n\
      \        self.smooth     = smooth        # EMA\n        self.set_output_multiple(block_size)\n\
      \        self._rssi_smooth = -100.0\n\n    def work(self, input_items, output_items):\n\
      \        n = self.block_size\n        x = input_items[0][:n]\n        power\
      \ = float(np.mean(np.abs(x)**2))\n        rssi_raw = 10.0 * np.log10(max(power,\
      \ 1e-12))\n        self._rssi_smooth = (\n            self.smooth * rssi_raw\
      \ +\n            (1.0 - self.smooth) * self._rssi_smooth\n        )\n      \
      \  output_items[0][:n] = np.full(n, self._rssi_smooth, dtype=np.float32)\n \
      \       return n\n"
    affinity: ''
    alias: ''
    block_size: '1024'
    comment: 'RSSI REAL desde PlutoSDR RX

      Calcula potencia en dBFS de las muestras IQ

      Suavizado EMA=0.2

      Habilitar con iio_pluto_source_single

      En simulacion usar rssi_sim en su lugar'
    maxoutbuf: '0'
    minoutbuf: '0'
    smooth: '0.2'
  states:
