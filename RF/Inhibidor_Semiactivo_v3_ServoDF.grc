- name: rssi_sim
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport math\nimport\
      \ random\nimport time\n\nclass blk(gr.sync_block):\n    \"\"\"Simulated RSSI\
      \ as a function of antenna pointing angle.\n\n    Input:  angle_deg (float)\n\
      \    Output: rssi_db (float)\n\n    Pattern: Gaussian mainlobe centered at src_angle_deg\
      \ with approximate beamwidth.\n    Adds random noise. Also prints best-angle\
      \ tracking periodically.\n    \"\"\"\n\n    def __init__(self, src_angle_deg=15.0,\
      \ beamwidth_deg=35.0, peak_db=-10.0, noise_std_db=1.5, print_hz=2.0):\n    \
      \    gr.sync_block.__init__(\n            self,\n            name='RSSI Simulator\
      \ (dB)',\n            in_sig=[np.float32],\n            out_sig=[np.float32],\n\
      \        )\n        self.src = float(src_angle_deg)\n        self.bw = float(beamwidth_deg)\n\
      \        self.peak = float(peak_db)\n        self.noise_std = float(noise_std_db)\n\
      \n        # sigma so that -3 dB roughly at +/- bw/2\n        self.sigma = (self.bw/2.0)\
      \ / math.sqrt(2.0*math.log(2.0))\n\n        self.best_rssi = -1e9\n        self.best_angle\
      \ = 0.0\n        self._t_last = time.time()\n        self._print_dt = 1.0 /\
      \ max(float(print_hz), 0.1)\n\n    def work(self, input_items, output_items):\n\
      \        ang = input_items[0]\n        out = output_items[0]\n        n = min(len(ang),\
      \ len(out))\n        for i in range(n):\n            a = float(ang[i])\n   \
      \         g = math.exp(-0.5 * ((a - self.src) / self.sigma) ** 2)  # 0..1\n\
      \            rssi = self.peak + 20.0*math.log10(max(g, 1e-6)) + random.gauss(0.0,\
      \ self.noise_std)\n\n            out[i] = np.float32(rssi)\n\n            if\
      \ rssi > self.best_rssi:\n                self.best_rssi = rssi\n          \
      \      self.best_angle = a\n\n        now = time.time()\n        if now - self._t_last\
      \ >= self._print_dt:\n            self._t_last = now\n            print(f\"\
      [SCAN] best_angle\u2248{self.best_angle:6.1f} deg | best_rssi\u2248{self.best_rssi:6.1f}\
      \ dB\")\n\n        return n"
    affinity: ''
    alias: ''
    beamwidth_deg: '35'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    noise_std_db: '1.5'
    peak_db: '-10'
    print_hz: '2.0'
    src_angle_deg: src_angle_deg
  states:
    _io_cache: '(''RSSI Simulator (dB)'', ''blk'', [(''src_angle_deg'', ''15.0''),
      (''beamwidth_deg'', ''35.0''), (''peak_db'', ''-10.0''), (''noise_std_db'',
      ''1.5''), (''print_hz'', ''2.0'')], [(''0'', ''float'', 1)], [(''0'', ''float'',
      1)], ''Simulated RSSI as a function of antenna pointing angle.\n\n    Input:  angle_deg
      (float)\n    Output: rssi_db (float)\n\n    Pattern: Gaussian mainlobe centered
      at src_angle_deg with approximate beamwidth.\n    Adds random noise. Also prints
      best-angle tracking periodically.\n    '', [])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [880, 1056.0]
    rotation: 0
    state: enabled
- name: servo_df_tracker
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport time\n\nclass\
      \ blk(gr.sync_block):\n    \"\"\"\n    Servo DF Tracker: estima DOA por barrido\
      \ de amplitud.\n\n    Principio: DF por amplitud (scan + max RSSI).\n    La\
      \ antena se mueve de min_angle a max_angle (servo).\n    En cada posicion se\
      \ mide el RSSI.\n    Al completar un semicilo se emite el angulo de maximo RSSI\n\
      \    como estimacion DOA.\n\n    Entradas:\n        in0 (float): angulo actual\
      \ del servo (grados)\n        in1 (float): RSSI en ese angulo (dBFS o dBm simulado)\n\
      \n    Salida:\n        out0 (float): angulo DOA estimado (grados) \u2014 se\
      \ actualiza\n                      al completar cada semicilo de barrido\n\n\
      \    Parametros:\n        min_angle_deg: limite inferior del barrido\n     \
      \   max_angle_deg: limite superior del barrido\n        hysteresis_db: cambio\
      \ minimo de RSSI para actualizar DOA\n        smooth:        suavizado EMA del\
      \ angulo de salida\n    \"\"\"\n\n    def __init__(self, min_angle_deg=-60.0,\
      \ max_angle_deg=60.0,\n                 hysteresis_db=2.0, smooth=0.15):\n \
      \       gr.sync_block.__init__(\n            self,\n            name='Servo\
      \ DF Tracker',\n            in_sig=[np.float32, np.float32],\n            out_sig=[np.float32],\n\
      \        )\n        self.min_a      = float(min_angle_deg)\n        self.max_a\
      \      = float(max_angle_deg)\n        self.hyst       = float(hysteresis_db)\n\
      \        self.smooth     = float(smooth)\n\n        # Historial del semiciclo\
      \ actual\n        self._angles  = []\n        self._rssis   = []\n        self._prev_ang\
      \ = None\n        self._direction = 1   # 1=subiendo, -1=bajando\n\n       \
      \ # DOA estimado actual (suavizado)\n        self._doa_smooth = 0.0\n      \
      \  self._best_rssi_cycle = -1e9\n\n        self._t_last_print = time.time()\n\
      \n    def work(self, input_items, output_items):\n        angles = input_items[0]\n\
      \        rssis  = input_items[1]\n        n = min(len(angles), len(rssis), len(output_items[0]))\n\
      \n        for i in range(n):\n            ang  = float(angles[i])\n        \
      \    rssi = float(rssis[i])\n\n            self._angles.append(ang)\n      \
      \      self._rssis.append(rssi)\n\n            # Detectar inversion del servo\
      \ (fin de semiciclo)\n            if self._prev_ang is not None:\n         \
      \       delta = ang - self._prev_ang\n                if len(self._angles) >\
      \ 3:\n                    if self._direction == 1 and delta < 0:\n         \
      \               # Fin semiciclo ascendente \u2192 calcular DOA\n           \
      \             self._direction = -1\n                        self._update_doa()\n\
      \                    elif self._direction == -1 and delta > 0:\n           \
      \             # Fin semiciclo descendente \u2192 calcular DOA\n            \
      \            self._direction = 1\n                        self._update_doa()\n\
      \            self._prev_ang = ang\n\n            output_items[0][i] = np.float32(self._doa_smooth)\n\
      \n        return n\n\n    def _update_doa(self):\n        if len(self._rssis)\
      \ < 3:\n            return\n        rs = np.array(self._rssis)\n        an =\
      \ np.array(self._angles)\n        peak_idx = int(np.argmax(rs))\n        peak_rssi\
      \ = rs[peak_idx]\n        peak_ang  = an[peak_idx]\n\n        # Solo actualizar\
      \ si el pico supera umbral de hist\xE9resis\n        if peak_rssi > self._best_rssi_cycle\
      \ - self.hyst:\n            self._best_rssi_cycle = peak_rssi\n            self._doa_smooth\
      \ = (\n                self.smooth * peak_ang +\n                (1.0 - self.smooth)\
      \ * self._doa_smooth\n            )\n            now = time.time()\n       \
      \     if now - self._t_last_print > 0.5:\n                self._t_last_print\
      \ = now\n                print(f\"[DF TRACKER] DOA estimado: {self._doa_smooth:6.1f}\
      \ deg \"\n                      f\"| pico RSSI: {peak_rssi:6.1f} dB @ {peak_ang:.1f}\
      \ deg\")\n\n        # Limpiar historial para el proximo semiciclo\n        self._angles\
      \ = []\n        self._rssis  = []\n"
    affinity: ''
    alias: ''
    comment: "SERVO DF TRACKER\nCombina angulo servo + RSSI \u2192 DOA estimado\n\
      Detecta fin de semiciclo automaticamente\nEmite angulo de maximo RSSI por semiciclo\n\
      Suavizado EMA=0.15 para estabilidad\nSalida \u2192 probe_doa_servo \u2192 beam_angle_deg\
      \ TX"
    hysteresis_db: '2.0'
    max_angle_deg: '60.0'
    maxoutbuf: '0'
    min_angle_deg: '-60.0'
    minoutbuf: '0'
    smooth: '0.15'
  states:
    _io_cache: "('Servo DF Tracker', 'blk', [('min_angle_deg', '-60.0'), ('max_angle_deg',\
      \ '60.0'), ('hysteresis_db', '2.0'), ('smooth', '0.15')], [('0', 'float', 1),\
      \ ('1', 'float', 1)], [('0', 'float', 1)], '\\n    Servo DF Tracker: estima\
      \ DOA por barrido de amplitud.\\n\\n    Principio: DF por amplitud (scan + max\
      \ RSSI).\\n    La antena se mueve de min_angle a max_angle (servo).\\n    En\
      \ cada posicion se mide el RSSI.\\n    Al completar un semicilo se emite el\
      \ angulo de maximo RSSI\\n    como estimacion DOA.\\n\\n    Entradas:\\n   \
      \     in0 (float): angulo actual del servo (grados)\\n        in1 (float): RSSI\
      \ en ese angulo (dBFS o dBm simulado)\\n\\n    Salida:\\n        out0 (float):\
      \ angulo DOA estimado (grados) \u2014 se actualiza\\n                      al\
      \ completar cada semicilo de barrido\\n\\n    Parametros:\\n        min_angle_deg:\
      \ limite inferior del barrido\\n        max_angle_deg: limite superior del barrido\\\
      n        hysteresis_db: cambio minimo de RSSI para actualizar DOA\\n       \
      \ smooth:        suavizado EMA del angulo de salida\\n    ', ['smooth'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1512, 1048.0]
    rotation: 0
    state: enabled
- name: servo_serial_writer
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\ntry:\n    import serial\n\
      \    _HAS_SERIAL = True\nexcept ImportError:\n    _HAS_SERIAL = False\nimport\
      \ time\n\nclass blk(gr.sync_block):\n    \"\"\"\n    Servo Serial Writer: convierte\
      \ angulo (grados) a pulso PWM\n    y lo envia por puerto serie a un Arduino/microcontrolador.\n\
      \n    Protocolo: envia texto \"ANG:XXX.X\\n\" a la velocidad\n    configurada.\
      \ El Arduino convierte a posicion de servo.\n\n    Ejemplo firmware Arduino:\n\
      \        if (Serial.available()) {\n            String s = Serial.readStringUntil('\\\
      n');\n            if (s.startsWith(\"ANG:\")) {\n                float ang =\
      \ s.substring(4).toFloat();\n                int us = map(ang, -90, 90, 1000,\
      \ 2000);\n                myServo.writeMicroseconds(us);\n            }\n  \
      \      }\n\n    Parametros:\n        port:     puerto serie (ej: /dev/ttyUSB0\
      \ o COM3)\n        baudrate: velocidad (default 115200)\n        min_us:   pulso\
      \ minimo en microsegundos (default 1000)\n        max_us:   pulso maximo en\
      \ microsegundos (default 2000)\n        rate_hz:  frecuencia maxima de envio\
      \ (default 50 Hz)\n    \"\"\"\n\n    def __init__(self, port='/dev/ttyUSB0',\
      \ baudrate=115200,\n                 min_us=1000, max_us=2000, rate_hz=50.0):\n\
      \        gr.sync_block.__init__(\n            self,\n            name='Servo\
      \ Serial Writer',\n            in_sig=[np.float32],\n            out_sig=None,\n\
      \        )\n        self.port     = port\n        self.baudrate = baudrate\n\
      \        self.min_us   = float(min_us)\n        self.max_us   = float(max_us)\n\
      \        self._dt      = 1.0 / max(float(rate_hz), 1.0)\n        self._t_last\
      \  = 0.0\n        self._ser     = None\n\n        if _HAS_SERIAL:\n        \
      \    try:\n                self._ser = serial.Serial(port, baudrate, timeout=0.1)\n\
      \                print(f\"[SERVO] Puerto abierto: {port} @ {baudrate} baud\"\
      )\n            except Exception as e:\n                print(f\"[SERVO] Error\
      \ abriendo {port}: {e}\")\n                print(\"[SERVO] Modo simulacion:\
      \ angulos por consola\")\n        else:\n            print(\"[SERVO] pyserial\
      \ no disponible. Instalar: pip install pyserial\")\n            print(\"[SERVO]\
      \ Modo simulacion: angulos por consola\")\n\n    def work(self, input_items,\
      \ output_items):\n        angles = input_items[0]\n        n = len(angles)\n\
      \n        now = time.time()\n        if now - self._t_last < self._dt:\n   \
      \         return n   # rate limiting\n\n        self._t_last = now\n       \
      \ ang = float(angles[-1])  # ultimo angulo del buffer\n\n        # Clamp a rango\
      \ fisico del servo (-90 a +90)\n        ang_clamped = max(-90.0, min(90.0, ang))\n\
      \n        # Calcular pulso PWM\n        t = (ang_clamped + 90.0) / 180.0   #\
      \ 0..1\n        pulse_us = self.min_us + t * (self.max_us - self.min_us)\n\n\
      \        msg = f\"ANG:{ang_clamped:.1f}\\n\"\n\n        if self._ser and self._ser.is_open:\n\
      \            try:\n                self._ser.write(msg.encode())\n         \
      \   except Exception as e:\n                print(f\"[SERVO] Error escritura:\
      \ {e}\")\n        else:\n            # Simulacion: solo consola cada 0.5s\n\
      \            print(f\"[SERVO SIM] {ang_clamped:6.1f} deg | {pulse_us:.0f} us\"\
      )\n\n        return n\n\n    def stop(self):\n        if self._ser and self._ser.is_open:\n\
      \            self._ser.close()\n            print(\"[SERVO] Puerto cerrado\"\
      )\n        return True\n"
    affinity: ''
    alias: ''
    baudrate: '115200'
    comment: "SERVO SERIAL WRITER\nConvierte angulo \u2192 pulso PWM \u2192 Arduino\
      \ \u2192 Servo\nProtocolo: \"ANG:XXX.X\\n\" por serie\nPuerto: /dev/ttyUSB0\
      \ (Linux) o COM3 (Windows)\nRequiere: pip install pyserial\nSin serial \u2192\
      \ modo consola (simulacion)\nVer docstring para firmware Arduino"
    max_us: '2000'
    maxoutbuf: '0'
    min_us: '1000'
    minoutbuf: '0'
    port: /dev/ttyUSB0
    rate_hz: '50.0'
  states:
    _io_cache: ('Servo Serial Writer', 'blk', [('port', '/dev/ttyUSB0'), ('baudrate',
      '115200'), ('min_us', '1000'), ('max_us', '2000'), ('rate_hz', '50.0')], [('0',
      'float', 1)], [], 'Servo angle to serial PWM', ['baudrate', 'max_us', 'min_us',
      'port', 'rate_hz'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2008, 832.0]
    rotation: 0
    state: enabled
